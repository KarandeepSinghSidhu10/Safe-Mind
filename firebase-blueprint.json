{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "phone": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "email"]
    },
    "Journal": {
      "title": "Journal",
      "description": "User journal entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "text": { "type": "string" },
        "mood": { "type": "string" }
      },
      "required": ["userId", "date", "text"]
    },
    "Incident": {
      "title": "Incident",
      "description": "Reported incident",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "time": { "type": "string" },
        "distance": { "type": "string" },
        "severity": { "type": "string" },
        "icon": { "type": "string" },
        "latOffset": { "type": "number" },
        "lngOffset": { "type": "number" },
        "confirmations": { "type": "number" }
      },
      "required": ["title", "desc", "severity"]
    },
    "Report": {
      "title": "Report",
      "description": "User submitted report",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "anonymous": { "type": "boolean" },
        "timestamp": { "type": "string" }
      },
      "required": ["type", "location", "description"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "User profiles"
    },
    "/journals/{journalId}": {
      "schema": { "$ref": "#/entities/Journal" },
      "description": "User journals"
    },
    "/incidents/{incidentId}": {
      "schema": { "$ref": "#/entities/Incident" },
      "description": "Public incidents"
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Submitted reports"
    }
  }
}
